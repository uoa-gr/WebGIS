            { "name": "publication_year", "type": "integer", "role": [] },
            { "name": "dataset_reference", "type": "text", "role": [] }
        ]
    },
    "filters": [
        { "column": "country", "label": "Country", "placeholder": "All Countries" },
        { "column": "ocean_sea", "label": "Ocean / Sea", "placeholder": "All Oceans/Seas" },
        { "column": "cement_type", "label": "Cement Type", "placeholder": "All Cement Types" },
        { "column": "formation_process", "label": "Formation Process", "placeholder": "All Processes" },
        { "column": "formation_location", "label": "Formation Location", "placeholder": "All Locations" },
        { "column": "dating_method", "label": "Dating Method", "placeholder": "All Methods" }
