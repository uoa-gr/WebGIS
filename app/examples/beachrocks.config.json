        { "column": "ocean_sea", "label": "Ocean/Sea", "type": "text" },
        { "column": "latitude", "label": "Latitude", "type": "coordinates" },
        { "column": "longitude", "label": "Longitude", "type": "coordinates" },
        { "column": "pos_type", "label": "Position Type", "type": "text" },
        { "column": "maximum_altitude", "label": "Max Altitude", "type": "text" },
        { "column": "minimum_altitude", "label": "Min Altitude", "type": "text" },
        { "column": "no_of_slabs", "label": "No. of Slabs", "type": "text" },
