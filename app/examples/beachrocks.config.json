        { "column": "dating_method", "label": "Dating Method", "type": "text" },
        { "column": "dated_sample", "label": "Dated Sample", "type": "text" },
        { "column": "estimated_age", "label": "Estimated Age", "type": "text" },
        { "column": "main_composition", "label": "Main Composition", "type": "text" },
        { "column": "cement_type", "label": "Cement Type", "type": "text" },
        { "column": "cement_microstructure", "label": "Cement Microstructure", "type": "text" },
        { "column": "formation_process", "label": "Formation Process", "type": "text" },
        { "column": "formation_location", "label": "Formation Location", "type": "text" },
        { "column": "water_table", "label": "Water Table", "type": "text" },
        { "column": "reference", "label": "Reference", "type": "text" },
        { "column": "publication_year", "label": "Publication Year", "type": "text" },
        { "column": "dataset_reference", "label": "Dataset Reference", "type": "link" }
