            { "name": "ocean_sea", "type": "text", "role": [] },
            { "name": "latitude", "type": "numeric", "role": ["latitude"] },
            { "name": "longitude", "type": "numeric", "role": ["longitude"] },
            { "name": "pos_type", "type": "text", "role": [] },
            { "name": "maximum_altitude", "type": "numeric", "role": [] },
            { "name": "minimum_altitude", "type": "numeric", "role": [] },
            { "name": "no_of_slabs", "type": "integer", "role": [] },
            { "name": "tidal_range", "type": "numeric", "role": [] },
            { "name": "dating_method", "type": "text", "role": [] },
            { "name": "dated_sample", "type": "text", "role": [] },
            { "name": "estimated_age", "type": "text", "role": [] },
            { "name": "main_composition", "type": "text", "role": [] },
