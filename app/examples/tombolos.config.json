            { "name": "tombolo_type", "type": "text", "role": [] },
            { "name": "tombolo_category", "type": "text", "role": [] },
            { "name": "latitude", "type": "numeric", "role": ["latitude"] },
            { "name": "longitude", "type": "numeric", "role": ["longitude"] },
            { "name": "length_m", "type": "numeric", "role": [] },
            { "name": "width_tombolo_m", "type": "numeric", "role": [] },
